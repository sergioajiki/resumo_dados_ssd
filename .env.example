# =============================================================================
# .env.example — Template de variáveis de ambiente
# resumo-dados-ssd | SES/MS — Superintendência de Saúde Digital
#
# COMO USAR:
#   1. Copie este arquivo para .env.local (nunca commitado — ver .gitignore)
#   2. Preencha os valores reais
#   3. No terminal, antes de iniciar a aplicação:
#        Windows CMD:   set VARIAVEL=valor
#        PowerShell:    $env:VARIAVEL = "valor"
#        Linux/macOS:   export VARIAVEL=valor
#
# O Spring Boot resolve automaticamente variáveis de ambiente:
#   DATASOURCE_ADAPTER  →  datasource.adapter
#   QLIK_HOST           →  datasource.qlik.host
#   etc.
# =============================================================================

# ---------------------------------------------------------------------------
# ADAPTADOR DE FONTE DE DADOS
# Valores: mock | qlik-engine | qlik-rest
# Padrão: mock (permite rodar sem conexão Qlik)
# ---------------------------------------------------------------------------
DATASOURCE_ADAPTER=mock

# ---------------------------------------------------------------------------
# CONFIGURAÇÃO QLIK SENSE — PAINÉIS PÚBLICOS SES/MS
#
# Host: servidor público, sem VPN necessária
# App ID: UUID encontrado na URL do WebSocket ao abrir o painel no browser
#   Como encontrar: DevTools → Network → WS → URL contém /app/{UUID}
#   Exemplo de URL: wss://paineispublicos.saude.ms.gov.br/anon/app/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Virtual Proxy: prefixo do proxy anônimo (/anon para acesso público)
# ---------------------------------------------------------------------------
QLIK_HOST=paineispublicos.saude.ms.gov.br
QLIK_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
QLIK_VIRTUAL_PROXY=/anon

# ---------------------------------------------------------------------------
# TIMEOUTS E PERFORMANCE (opcionais — os padrões são suficientes)
# ---------------------------------------------------------------------------
# QLIK_CONNECT_TIMEOUT_MS=10000
# QLIK_READ_TIMEOUT_MS=30000
# QLIK_PAGE_SIZE=5000
