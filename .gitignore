# =============================================================================
# .gitignore — resumo-dados-ssd
# ETL Java 21 + Spring Boot 3.x | SES/MS — Superintendência de Saúde Digital
# =============================================================================

# ---------------------------------------------------------------------------
# Build e compilação Maven
# ---------------------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ---------------------------------------------------------------------------
# Bytecode Java
# ---------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
*.nar

# ---------------------------------------------------------------------------
# Banco de dados H2 (arquivo local — nunca versionar dados extraídos)
# ---------------------------------------------------------------------------
data/
*.db
*.mv.db
*.trace.db

# ---------------------------------------------------------------------------
# Logs de aplicação
# ---------------------------------------------------------------------------
*.log
logs/
spring.log

# ---------------------------------------------------------------------------
# IDEs — IntelliJ IDEA
# ---------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
out/
.idea_modules/
# Exceção: o pacote adapter/out/ é código-fonte, não build output
!src/**/out/

# ---------------------------------------------------------------------------
# IDEs — VS Code
# ---------------------------------------------------------------------------
.vscode/
*.code-workspace

# ---------------------------------------------------------------------------
# IDEs — Eclipse / STS
# ---------------------------------------------------------------------------
.classpath
.project
.settings/
.factorypath
bin/

# ---------------------------------------------------------------------------
# IDEs — NetBeans
# ---------------------------------------------------------------------------
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ---------------------------------------------------------------------------
# Segredos e configurações de ambiente (NUNCA versionar)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
# Script de inicialização local (carrega .env.local com segredos)
start-dev.ps1
application-prod.yml
application-secrets.yml
application-local.yml
*-credentials.yml
*-credentials.json
secrets/

# ---------------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ---------------------------------------------------------------------------
# Maven Wrapper (manter o wrapper, ignorar o cache local)
# ---------------------------------------------------------------------------
.mvn/repository/

# ---------------------------------------------------------------------------
# Relatórios de testes e cobertura (gerados pelo CI — não versionar)
# ---------------------------------------------------------------------------
surefire-reports/
failsafe-reports/
jacoco.exec
jacoco/

# ---------------------------------------------------------------------------
# Arquivos temporários e de patch
# ---------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig
*.rej
*.patch

# ---------------------------------------------------------------------------
# Docker (se usado no futuro)
# ---------------------------------------------------------------------------
.dockerignore

# ---------------------------------------------------------------------------
# Node / frontend (se adicionado na Fase 10)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
